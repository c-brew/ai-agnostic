{
  "name": "ai-agnostic",
  "version": "0.1.1",
  "description": "Seamlessly migrate AI workspaces between Claude, ChatGPT, and other platforms",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-agnostic": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "claude",
    "chatgpt",
    "openai",
    "anthropic",
    "migration",
    "portability",
    "mcp",
    "skills"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
